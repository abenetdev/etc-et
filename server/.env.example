# ── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database Configuration ───────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/mern-ecommerce

# ── Security Configuration ───────────────────────────────────────────────────
# JWT Secret Key - Generate a strong random string for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# ── Chapa Payment Gateway Configuration ───────────────────────────────────────
# Get your keys from: https://dashboard.chapa.co/
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_WEBHOOK_SECRET=your_webhook_secret_from_chapa_dashboard

# ── Client Configuration ─────────────────────────────────────────────────────
CLIENT_BASE_URL=http://localhost:5173

# ── Cloudinary Configuration (for image uploads) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Email Configuration (optional - for notifications) ───────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_email_password
